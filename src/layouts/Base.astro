---
/**
 * Base layout for agenticmedia.cc — wraps AppShell with apex SEO metadata.
 *
 * Uses AppShell with:
 *   brand="agenticmedia"   — default nav header strip + mark
 *   user={null}            — apex is anonymous-only, no auth
 *   bareFooter={true}      — apex owns its own footer in index.astro
 *
 * Extra SEO/OG tags are injected via the AppShell "head" named slot so
 * search engines and social previews pick them up correctly.
 */
import AppShell from '@ui/layouts/AppShell.astro';

export interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
}

const {
  title = 'agentic media — your AI agent, your channels',
  description = 'commons puts an AI agent to work across your messaging channels — WhatsApp, Telegram, web chat — managed, audited, and always under your control. Request beta access.',
  canonicalUrl = Astro.url.href,
} = Astro.props;
---

<AppShell
  pageTitle={title}
  brand="agenticmedia"
  user={null}
  bareFooter={true}
>
  <!-- SEO + OG meta injected into AppShell's <head> via named slot -->
  <meta slot="head" name="description" content={description} />
  <link slot="head" rel="canonical" href={canonicalUrl} />
  <meta slot="head" property="og:title" content={title} />
  <meta slot="head" property="og:description" content={description} />
  <meta slot="head" property="og:type" content="website" />
  <meta slot="head" property="og:url" content={canonicalUrl} />

  <!-- Page-specific styles (apex hero, form, beat-grid, footer) -->
  <link slot="head" rel="stylesheet" href="/styles/global.css" />

  <!-- Page content -->
  <slot />
</AppShell>
