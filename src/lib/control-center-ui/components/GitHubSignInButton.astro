---
/**
 * GitHubSignInButton — branded GitHub OAuth CTA
 *
 * Black background, white text, GitHub mark icon (left, 20px).
 * Full-width inside auth card (100%).
 * Single use per page — on the Login screen only.
 *
 * The href should be the OAuth initiation URL, e.g.:
 *   /oauth/github?next=/
 *   /oauth/github?next=/openclaw
 */

interface Props {
  /** OAuth initiation URL. */
  href?: string;
  /** Button label. Defaults to 'Sign in with GitHub'. */
  label?: string;
}

const {
  href = '/oauth/github?next=/',
  label = 'Sign in with GitHub',
} = Astro.props;
---

<a class="dsh-gh-btn" href={href}>
  <!-- GitHub Invertocat mark -->
  <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
    <path d="M12 .5a11.5 11.5 0 0 0-3.64 22.42c.58.11.79-.25.79-.56v-2c-3.2.7-3.88-1.36-3.88-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.02 1.75 2.68 1.25 3.34.95.1-.74.4-1.25.72-1.54-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.4-5.27 5.69.41.35.78 1.05.78 2.12v3.14c0 .31.21.68.8.56A11.5 11.5 0 0 0 12 .5z"/>
  </svg>
  {label}
</a>

<style>
  .dsh-gh-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    height: 44px;
    padding: 0 16px;
    border-radius: var(--am-btn-radius);
    background: var(--am-base);
    color: var(--am-text);
    border: 1px solid var(--am-border-2);
    font-family: var(--am-font-display);
    font-weight: var(--am-fw-ui);
    font-size: 14px;
    letter-spacing: 0.01em;
    cursor: pointer;
    text-decoration: none;
    transition:
      background var(--am-dur-fast) var(--am-ease),
      border-color var(--am-dur-fast) var(--am-ease);
  }

  .dsh-gh-btn:hover {
    background: var(--am-surface);
    border-color: var(--am-border-3);
  }

  .dsh-gh-btn:active {
    background: var(--am-surface-2);
  }

  .dsh-gh-btn svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
</style>
