---
import Base from '../layouts/Base.astro';

// TURNSTILE_SITE_KEY is the PUBLIC site key for the agenticmedia.cc Turnstile
// widget. It ships to every visitor as a data-sitekey attribute — safe to
// embed in HTML by design. Site keys are ROUTABLE PUBLIC IDENTIFIERS, not
// secrets (the matching SECRET key lives only in oauth-broker's
// TURNSTILE_SECRET_KEY env, which performs server-side verification of the
// one-time tokens this widget produces). Hardcoded as a default 2026-05-10
// because CF Pages was not injecting deployment_configs.production.env_vars
// into the build container despite multiple PATCH attempts; the env-var path
// can still be used to override per-environment if needed.
const turnstileSiteKey = import.meta.env.TURNSTILE_SITE_KEY || '0x4AAAAAADMne5OBUg7sRxyD';
---

<Base
  title="agentic media — commons beta access"
  description="commons puts an AI agent to work across your messaging channels. Managed, audited, always under your control. Request early access to the beta."
>
  <main>

    <!-- ─────────────────────────────────────────────────────────────────────
         Section 1: Hero
         ───────────────────────────────────────────────────────────────────── -->
    <section class="hero section" aria-label="Hero">
      <!-- OverlordEye — slow drifting particles + scanning beam, decorative.
           Auto-disables under prefers-reduced-motion or when --am-anim-enabled=0.
           Source: design-system v1 ui_kits/agent-ui/overlord-eye.js -->
      <canvas id="overlord-eye" class="hero__overlord-eye" aria-hidden="true"></canvas>
      <div class="container" style="display:flex;flex-direction:column;align-items:center;gap:2rem;text-align:center;position:relative;z-index:1;">

        <!-- Mark + eye-pulse cluster (#62: inline SVG so currentColor flows through on dark bg) -->
        <div class="hero__mark-cluster" aria-hidden="true">
          <!-- Agentic Media mark (inline so currentColor works on dark hero) -->
          <svg class="hero__mark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="72" height="72" role="img" aria-label="Agentic Media">
            <defs>
              <clipPath id="am-square-hero">
                <rect x="6" y="6" width="52" height="52" rx="10"/>
              </clipPath>
            </defs>
            <g clip-path="url(#am-square-hero)">
              <rect x="6" y="6" width="52" height="52" rx="10" fill="none" stroke="currentColor" stroke-width="2.5"/>
              <path d="M32 14 L50 32 L32 50 L14 32 Z" fill="none" stroke="currentColor" stroke-width="2"/>
              <path d="M32 22 L42 32 L32 42 L22 32 Z" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.7"/>
              <circle cx="34" cy="32" r="3" fill="currentColor"/>
              <path d="M10 14 L10 10 L14 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
              <path d="M50 10 L54 10 L54 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
              <path d="M54 50 L54 54 L50 54" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
              <path d="M14 54 L10 54 L10 50" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
            </g>
          </svg>
          <!-- Eye-pulse dot — the watching eye, design language from dashboard -->
          <div class="hero__eye blink" aria-hidden="true"></div>
        </div>

        <!-- Wordmark (inline so currentColor works on dark bg) -->
        <svg class="hero__wordmark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 280 64" width="280" height="28" role="img" aria-label="agentic media">
          <defs>
            <clipPath id="am-wm-square-hero">
              <rect x="6" y="6" width="52" height="52" rx="10"/>
            </clipPath>
          </defs>
          <g clip-path="url(#am-wm-square-hero)" color="currentColor">
            <rect x="6" y="6" width="52" height="52" rx="10" fill="none" stroke="currentColor" stroke-width="2.5"/>
            <path d="M32 14 L50 32 L32 50 L14 32 Z" fill="none" stroke="currentColor" stroke-width="2"/>
            <path d="M32 22 L42 32 L32 42 L22 32 Z" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.7"/>
            <circle cx="34" cy="32" r="3" fill="currentColor"/>
            <path d="M10 14 L10 10 L14 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
            <path d="M50 10 L54 10 L54 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
            <path d="M54 50 L54 54 L50 54" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
            <path d="M14 54 L10 54 L10 50" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
          </g>
          <text x="76" y="40" font-family="Blinker, ui-sans-serif, system-ui, sans-serif" font-weight="800" font-size="26" letter-spacing="-0.5" fill="currentColor">agentic<tspan opacity="0.55">media</tspan></text>
        </svg>

        <p class="hero__eyebrow">Private beta — now open</p>

        <h1 class="hero__headline">
          Your AI agent, running your channels
        </h1>

        <p class="hero__subhead">
          commons gives you one AI agent that works across WhatsApp, Telegram, and web chat —
          configured by you, audited by default, and paused the moment you ask.
        </p>

        <div class="hero__cta-group">
          <a href="#beta-invite" class="am-btn am-btn--iris am-btn--lg">
            Request beta access to commons
          </a>
          <span style="font-size:var(--am-text-sm,13px);color:var(--am-muted);">Free during the beta wave &mdash; no credit card needed</span>
        </div>

      </div>
    </section>

    <!-- ─────────────────────────────────────────────────────────────────────
         Section 2: Beta-invite form
         ───────────────────────────────────────────────────────────────────── -->
    <section class="invite-form-section section" id="beta-invite" aria-label="Request beta access">
      <div class="container">

        <div>
          <p class="invite-form__label-text">Reserve your spot</p>
          <p class="invite-form__sub">Drop your email. We'll send your invite when your wave opens.</p>
        </div>

        <form
          class="invite-form"
          id="invite-form"
          action="/api/beta-invite"
          method="POST"
          novalidate
        >
          <div class="invite-form__row">
            <label for="invite-email" class="sr-only">Email address</label>
            <input
              type="email"
              id="invite-email"
              name="email"
              class="invite-form__input"
              placeholder="you@example.com"
              required
              autocomplete="email"
              inputmode="email"
            />
            <button type="submit" class="am-btn am-btn--primary am-btn--md">
              Request access
            </button>
          </div>

          <div>
            <label for="invite-handle" class="sr-only">Social handle (optional)</label>
            <input
              type="text"
              id="invite-handle"
              name="handle"
              class="invite-form__input invite-form__handle"
              placeholder="@handle (optional — Twitter/X, LinkedIn, Telegram)"
              autocomplete="off"
            />
          </div>

          <!-- Cloudflare Turnstile bot-protection widget.
               The widget is rendered client-side by the Turnstile JS bundle
               loaded below (is:inline — not deferred, so the widget is ready
               before the user submits). On submit, turnstile.getResponse()
               returns the one-time token; we forward it to the relay.
               If TURNSTILE_SITE_KEY is empty (local dev without env), the
               widget div is still rendered but the JS no-ops — form still
               submits and relay returns 422 missing_turnstile_token, which
               the error handler surfaces. -->
          {turnstileSiteKey && (
            <div
              class="cf-turnstile invite-form__turnstile"
              data-sitekey={turnstileSiteKey}
              data-theme="dark"
              data-size="normal"
            ></div>
          )}
          {!turnstileSiteKey && (
            <p class="invite-form__note invite-form__note--warn">
              (Bot protection widget loading...)
            </p>
          )}

          <p class="invite-form__note">
            We send one email when your wave opens. No newsletters, no spam.
          </p>
        </form>

        <!-- Success toast -->
        <div class="invite-toast" id="invite-toast" role="status" aria-live="polite">
          <svg class="invite-toast__icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
            <path d="M6.5 10.5l2.5 2.5 4.5-5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>You're on the list — we'll email you when your wave opens.</span>
        </div>

        <!-- Error toast (relay 4xx / network error) -->
        <div class="invite-toast invite-toast--error" id="invite-error" role="alert" aria-live="assertive">
          <svg class="invite-toast__icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
            <path d="M10 6v5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
            <circle cx="10" cy="14" r="0.75" fill="currentColor"/>
          </svg>
          <span id="invite-error-msg">Something went wrong — please try again.</span>
        </div>

      </div>
    </section>

    <!-- ─────────────────────────────────────────────────────────────────────
         Section 3: 3-card beat-grid
         ───────────────────────────────────────────────────────────────────── -->
    <section class="section" aria-label="How commons works">
      <div class="container">

        <div class="beat-grid__section-label">
          <h2>What you get with commons</h2>
          <p>One agent. Your channels. Full audit trail.</p>
        </div>

        <div class="beat-grid">

          <!-- Card A: What commons IS -->
          <article class="beat-card">
            <div class="beat-card__icon" aria-hidden="true">
              <svg viewBox="0 0 20 20" fill="none">
                <rect x="2" y="4" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
                <path d="M7 8l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="beat-card__title">One agent, all your channels</h3>
            <p class="beat-card__body">
              commons gives you a personal AI agent that works wherever you already talk —
              WhatsApp, Telegram, or web chat. You configure its identity and context once.
              It handles the rest.
            </p>
          </article>

          <!-- Card B: Trial terms -->
          <article class="beat-card">
            <div class="beat-card__icon" aria-hidden="true">
              <svg viewBox="0 0 20 20" fill="none">
                <path d="M10 2l2 6h6l-5 4 2 6-5-4-5 4 2-6L2 8h6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="beat-card__title">Free during beta, simple after</h3>
            <p class="beat-card__body">
              Beta access is free while we tune capacity and pricing. When beta closes,
              commons moves to a clear monthly plan — no surprise bills, no lock-in.
              You stay in control of what your agent can and can't do.
            </p>
          </article>

          <!-- Card C: Audited by default -->
          <article class="beat-card">
            <div class="beat-card__icon" aria-hidden="true">
              <svg viewBox="0 0 20 20" fill="none">
                <circle cx="10" cy="8" r="3" stroke="currentColor" stroke-width="1.5"/>
                <path d="M2 17c0-3.3 3.6-6 8-6s8 2.7 8 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M14 3l1 1-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="beat-card__title">Audited by default</h3>
            <p class="beat-card__body">
              Every action your agent takes goes through an operator review layer before
              it leaves the system. Nothing sends without a log. You can pause, inspect,
              or roll back any action at any time.
            </p>
          </article>

        </div>
      </div>
    </section>

  </main>

  <!-- ─────────────────────────────────────────────────────────────────────
       Footer
       ───────────────────────────────────────────────────────────────────── -->
  <footer class="site-footer" aria-label="Site footer">
    <div class="container">
      <div class="site-footer__brand">
        <!-- Inline mark so currentColor works on dark footer bg -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="24" height="24" aria-hidden="true" focusable="false">
          <defs>
            <clipPath id="am-square-footer">
              <rect x="6" y="6" width="52" height="52" rx="10"/>
            </clipPath>
          </defs>
          <g clip-path="url(#am-square-footer)">
            <rect x="6" y="6" width="52" height="52" rx="10" fill="none" stroke="currentColor" stroke-width="2.5"/>
            <path d="M32 14 L50 32 L32 50 L14 32 Z" fill="none" stroke="currentColor" stroke-width="2"/>
            <path d="M32 22 L42 32 L32 42 L22 32 Z" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.7"/>
            <circle cx="34" cy="32" r="3" fill="currentColor"/>
            <path d="M10 14 L10 10 L14 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
            <path d="M50 10 L54 10 L54 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
            <path d="M54 50 L54 54 L50 54" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
            <path d="M14 54 L10 54 L10 50" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
          </g>
        </svg>
        <!-- Inline wordmark so currentColor works on dark footer bg -->
        <svg class="site-footer__wordmark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 280 64" aria-label="agentic media" focusable="false">
          <defs>
            <clipPath id="am-wm-square-footer">
              <rect x="6" y="6" width="52" height="52" rx="10"/>
            </clipPath>
          </defs>
          <g clip-path="url(#am-wm-square-footer)" color="currentColor">
            <rect x="6" y="6" width="52" height="52" rx="10" fill="none" stroke="currentColor" stroke-width="2.5"/>
            <path d="M32 14 L50 32 L32 50 L14 32 Z" fill="none" stroke="currentColor" stroke-width="2"/>
            <path d="M32 22 L42 32 L32 42 L22 32 Z" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.7"/>
            <circle cx="34" cy="32" r="3" fill="currentColor"/>
            <path d="M10 14 L10 10 L14 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
            <path d="M50 10 L54 10 L54 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
            <path d="M54 50 L54 54 L50 54" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
            <path d="M14 54 L10 54 L10 50" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
          </g>
          <text x="76" y="40" font-family="Blinker, ui-sans-serif, system-ui, sans-serif" font-weight="800" font-size="26" letter-spacing="-0.5" fill="currentColor">agentic<tspan opacity="0.55">media</tspan></text>
        </svg>
      </div>
      <p class="site-footer__tagline">audited by default</p>
      <p class="site-footer__meta">&copy; {new Date().getFullYear()} agentic media</p>
    </div>
  </footer>

  <!-- ── OverlordEye mount (decorative hero animation) ─────────────────── -->
  <script is:inline src="/scripts/overlord-eye.js"></script>
  <script is:inline>
    (function () {
      var c = document.getElementById('overlord-eye');
      if (c && window.OverlordEye) {
        // Canvas API needs literal colors (no CSS vars); resolve from
        // the document's computed --am-iris with a hex fallback.
        var rs = getComputedStyle(document.documentElement);
        var iris = rs.getPropertyValue('--am-iris').trim() || '#7c5cff';
        window.OverlordEye.mount(c, {
          density: 0.5,
          beamPeriod: 14000,
          color: iris,
          beamColor: '#6ee7b7',
        });
      }
    })();
  </script>

  <!-- ── Cloudflare Turnstile JS bundle ──────────────────────────────── -->
  <!-- Loaded synchronously (is:inline) so the widget renders before submit.
       Only injected when TURNSTILE_SITE_KEY is set (prevents a pointless
       script load in local dev with no key). -->
  {turnstileSiteKey && (
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  )}

  <!-- ── Form interaction script ───────────────────────────────────────── -->
  <!-- Task #161: relay-wired form with Turnstile token + relay error UX.
       Reads the Turnstile one-time token from window.turnstile.getResponse()
       at submit time, forwards it alongside {email, source, ua} to the CF
       Pages Function at /api/beta-invite, which proxies to the oauth-broker
       relay. The relay performs server-side Turnstile verification.

       Error mapping:
         409 email_exists     → "Looks like you're already on the list."
         422 missing_turnstile_token → "Bot check required — please wait for the widget."
         422 invalid_email    → re-focus email field
         422 *                → generic relay error message
         429                  → "Too many attempts — please try again in a minute."
         502/network          → generic retry message -->
  <script>
    const form = document.getElementById('invite-form') as HTMLFormElement | null;
    const toast = document.getElementById('invite-toast');
    const errorBox = document.getElementById('invite-error');
    const errorMsg = document.getElementById('invite-error-msg');

    function showError(msg: string) {
      if (errorMsg) errorMsg.textContent = msg;
      if (errorBox) errorBox.classList.add('invite-toast--visible');
    }

    function hideError() {
      if (errorBox) errorBox.classList.remove('invite-toast--visible');
    }

    function errorForCode(code: string, status: number): string {
      if (status === 409) return "Looks like you're already on the list — we'll email you when your wave opens.";
      if (code === 'missing_turnstile_token') return "Bot check required — please wait a moment for the security widget to load, then try again.";
      if (code === 'invalid_email') return "Please enter a valid email address.";
      if (status === 429) return "Too many attempts — please try again in a minute.";
      return "Something went wrong. Please try again in a moment.";
    }

    if (form && toast) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        hideError();

        const emailInput = form.querySelector<HTMLInputElement>('#invite-email');

        if (!emailInput?.value || !emailInput.checkValidity()) {
          emailInput?.focus();
          emailInput?.reportValidity();
          return;
        }

        // Get Turnstile token. window.turnstile is defined by the CF bundle.
        // If undefined (local dev / bundle not loaded), send empty string —
        // relay will return 422 missing_turnstile_token which surfaces below.
        const turnstileToken: string = (window as any).turnstile?.getResponse() || '';

        const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
        if (submitBtn) {
          submitBtn.textContent = 'Sending…';
          submitBtn.disabled = true;
          submitBtn.classList.add('am-btn--pending');
        }

        const resetBtn = () => {
          if (submitBtn) {
            submitBtn.textContent = 'Request access';
            submitBtn.disabled = false;
            submitBtn.classList.remove('am-btn--pending');
          }
          // Reset widget so user can retry
          try { (window as any).turnstile?.reset(); } catch {}
        };

        try {
          const res = await fetch('/api/beta-invite', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              email: emailInput.value.trim(),
              turnstile_token: turnstileToken,
            }),
          });

          if (res.ok) {
            // Success path
            form.style.display = 'none';
            toast.classList.add('invite-toast--visible');
            return;
          }

          // Error path — parse relay error code
          let data: { error?: string } = {};
          try { data = await res.json(); } catch {}
          const code = data.error || '';

          // 409 is a soft success — email already registered
          if (res.status === 409) {
            form.style.display = 'none';
            toast.classList.add('invite-toast--visible');
            return;
          }

          // Re-focus email for email shape errors
          if (code === 'invalid_email') {
            emailInput.focus();
          }

          showError(errorForCode(code, res.status));
          resetBtn();

        } catch {
          // Network error
          showError("Network error — please check your connection and try again.");
          resetBtn();
        }
      });
    }
  </script>

  <!-- Skip link + Turnstile widget spacing + error toast -->
  <style>
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    /* Turnstile widget — block-level with breathing room */
    .invite-form__turnstile {
      margin: 0.75rem 0;
    }

    /* Error toast — red accent vs green success toast */
    .invite-toast--error {
      display: none;
      border-left-color: var(--am-danger, #ef4444);
      color: var(--am-danger, #ef4444);
    }
    .invite-toast--error.invite-toast--visible {
      display: flex;
    }

    /* Dev-only warning note */
    .invite-form__note--warn {
      color: var(--am-muted);
      font-style: italic;
    }
  </style>
</Base>
